# /etc/linda/linda.env — production runtime config for Linda Agent.
# chmod 600, owner linda:linda.
#
# See packages/linda-agent/.env.example for full variable reference.

# --- Firm identity ---
FIRM_ID=linda-clinic
LOCALE=ru

# --- PSF Engine (on Vercel) ---
PSF_ENGINE_URL=https://CHANGE-ME.vercel.app
EDGE_ID=linda-prod-edge
FIRM_SHARED_SECRET=CHANGE-ME

# --- LLM ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=CHANGE-ME

# --- Telegram (enabled first for smoke test) ---
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=CHANGE-ME
# Comma-separated numeric TG user IDs. REQUIRED in prod.
TELEGRAM_ALLOWED_USER_IDS=
# Numeric TG ids of admins (intersection with ALLOWED_USER_IDS).
ALLOWED_ADMIN_IDS=

# --- WhatsApp (disabled until first QR scan) ---
WHATSAPP_ENABLED=false
# Comma-separated phone numbers WITHOUT @s.whatsapp.net.
WHATSAPP_ALLOWED_USER_IDS=
