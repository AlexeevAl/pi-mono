{
	"name": "@psf/linda",
	"version": "0.1.0",
	"description": "Linda — conversational intelligence layer for PSF Engine",
	"type": "module",
	"bin": {
		"linda": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.65.2",
		"@mariozechner/pi-ai": "^0.65.2",
		"@mariozechner/pi-tui": "^0.65.2",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.5.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"typescript": "^5.7.3"
	},
	"keywords": [
		"psf",
		"linda",
		"agent",
		"telegram",
		"conversational"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
