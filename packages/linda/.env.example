# ============================================================================
# Linda — Firm Runtime Config Template
# Copy to .env and fill in values, OR run `linda-create-firm` for a wizard.
#
# Architecture: one Linda instance = one firm.
# Two role-aware channels:
#   Block 2 → WhatsApp  = client agent  (intake, collect, guide)
#   Block 3 → Telegram  = admin agent   (browse, override, message)
# ============================================================================

# ----------------------------------------------------------------------------
# Block 1 — Firm Identity
# ----------------------------------------------------------------------------

# Unique firm identifier — used in PSF requests, chatKey namespace, and logs
FIRM_ID=pi_default

# Human-readable name — injected into the system prompt header
FIRM_NAME=Pi Default

# Comma-separated list of allowed PSF pack IDs.
# Leave empty to allow all packs (dev / single-firm setup).
# Example: FIRM_ACTIVE_PACKS=relocation_v1,financial_v1
FIRM_ACTIVE_PACKS=

# Optional: skip intent detection for single-scenario firms.
# Must be present in FIRM_ACTIVE_PACKS (or FIRM_ACTIVE_PACKS must be empty).
# FIRM_DEFAULT_PACK_ID=relocation_v1

# ----------------------------------------------------------------------------
# Block 4 — Web Chat
# Linda serves its own HTTP server: GET / = chat UI, POST /chat = API.
# ----------------------------------------------------------------------------

WEB_ENABLED=false

# HTTP port for the web chat server
# WEB_PORT=3034

# Role for web sessions: client (default) | admin
# WEB_ROLE=client

# Allowed CORS origins (comma-separated). * = all.
# WEB_ALLOWED_ORIGINS=https://yoursite.com

# Conversation language hint injected into system prompt: ru | en | he
FIRM_LANGUAGE=ru

# Conversation tone: warm (default) | formal | neutral
# FIRM_TONE=warm

# ----------------------------------------------------------------------------
# Block 2 — Client Agent (WhatsApp)
# WhatsApp = intake channel. Handles user messages, runs client pipeline.
# Tools: submit_data only. Guardrails: strict.
# ----------------------------------------------------------------------------

WHATSAPP_ENABLED=true

# Baileys session storage — path where QR auth state is saved
WHATSAPP_AUTH_DIR=./.linda/auth/pi_default-whatsapp

# Phone number whitelist (comma-separated, without @s.whatsapp.net)
# Leave empty to allow all numbers.
# WHATSAPP_ALLOWED_USER_IDS=

# ----------------------------------------------------------------------------
# Block 3 — Admin Agent (Telegram)
# Telegram = operator channel. Session browsing, overrides, client messaging.
# Tools: submit_data + list_sessions + view_session + override_field + send_to_client
# Guardrails: relaxed. Session scope: all.
# ----------------------------------------------------------------------------

TELEGRAM_ADMIN_ENABLED=true

# Telegram bot token from @BotFather — required when admin agent is enabled
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Numeric Telegram user IDs (comma-separated). STRONGLY recommended for prod.
# Leave empty = anyone who finds the bot can act as admin.
TELEGRAM_ALLOWED_USER_IDS=

# ----------------------------------------------------------------------------
# Infrastructure — PSF + LLM
# ----------------------------------------------------------------------------

PSF_BASE_URL=http://localhost:3000
PSF_SHARED_SECRET=psf_hermes_secret_123

LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

# Set the key matching LLM_PROVIDER
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Alternative: multi-provider key map
# LLM_API_KEYS=anthropic=sk-ant-...,openai=sk-...
