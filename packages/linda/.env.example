# ============================================================================
# Linda — Environment Variables
# Copy to .env and fill in values before running.
# ============================================================================

# PSF Engine connection
PSF_BASE_URL=http://localhost:3000
PSF_SHARED_SECRET=psf_hermes_secret_123

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: restrict access to specific Telegram user IDs (comma-separated)
# Leave empty to allow all users
TELEGRAM_ALLOWED_USER_IDS=

# LLM provider and model
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

# API keys — set the one matching your LLM_PROVIDER
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Alternative: multi-provider key map (provider=key,provider2=key2)
# LLM_API_KEYS=anthropic=sk-ant-...,openai=sk-...

# WhatsApp (optional)
# Auth state path, defaults to ./.linda/auth-whatsapp
# WHATSAPP_AUTH_DIR=./.linda/auth-whatsapp
# Optional: restrict access to specific WhatsApp phone numbers (comma-separated, without @s.whatsapp.net)
# WHATSAPP_ALLOWED_USER_IDS=
