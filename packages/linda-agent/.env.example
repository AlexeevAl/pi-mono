# ============================================================================
# Linda Agent — Runtime Config Template
# Copy to .env and fill in values.
#
# Architecture:
#   WhatsApp → LindaClientAgent  (intake, collect, guide)
#   Telegram → LindaAdminAgent   (browse, override, message)
#   Web      → LindaClientAgent | LindaAdminAgent (HTTP/UI shell)
# ============================================================================

# ----------------------------------------------------------------------------
# Block 1 — Firm Identity
# ----------------------------------------------------------------------------

# Deployment model: one linda-agent process per firm.
# Do not share FIRM_ID, EDGE_ID, FIRM_SHARED_SECRET, or WHATSAPP_AUTH_DIR across firms.

# Unique firm identifier (used in API headers and logs)
FIRM_ID=linda-clinic

# Locale for agent responses: ru | en | he
LOCALE=ru

# ----------------------------------------------------------------------------
# Block 2 — Backend (psf-engine-v2 / linda-clinic-edge)
# ----------------------------------------------------------------------------

# URL of the PSF engine HTTP API
PSF_ENGINE_URL=http://localhost:3050

# Edge identifier for this agent instance
EDGE_ID=linda-local-edge

# Shared secret — must match BRIDGE_SHARED_SECRET on the server side
FIRM_SHARED_SECRET=psf_hermes_secret_123

# Optional. If true, startup fails when /api/agent/runtime-config is unavailable.
LINDA_RUNTIME_CONFIG_REQUIRED=false

# ----------------------------------------------------------------------------
# Block 3 — LLM
# ----------------------------------------------------------------------------

LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------------
# Block 4 — WhatsApp (Client Agent)
# ----------------------------------------------------------------------------

WHATSAPP_ENABLED=true

# Path where Baileys stores the QR session (will be created if missing)
# Must be unique per firm/WhatsApp number.
WHATSAPP_AUTH_DIR=./.linda/auth/linda-whatsapp

# Allowlist of phone numbers (without the @s.whatsapp.net suffix).
# Leave empty to allow ALL numbers (dev only — NEVER for prod without list).
# WHATSAPP_ALLOWED_USER_IDS=79991234567,79997654321

# ----------------------------------------------------------------------------
# Block 5 — Telegram (Admin Agent)
# ----------------------------------------------------------------------------

TELEGRAM_ENABLED=true

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowlist of NUMERIC Telegram user IDs (comma-separated).
# STRONGLY recommended in production. Empty = anyone can act as admin.
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Long-poll timeout in seconds (default: 30)
# TELEGRAM_POLL_TIMEOUT_SEC=30

# ----------------------------------------------------------------------------
# Block 6 — Web Channel
# ----------------------------------------------------------------------------

WEB_ENABLED=false

# client | admin
WEB_ROLE=client

# HTTP port for the built-in web shell
WEB_PORT=3034

# CORS allowlist. "*" allows any origin.
WEB_ALLOWED_ORIGINS=*

# Optional fixed actor ID for demos.
# For admin mode, set this to an allowed admin ID if TELEGRAM/UI policy expects it.
# WEB_DEFAULT_ACTOR_ID=user_web_demo
