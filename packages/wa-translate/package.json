{
	"name": "@psf/wa-translate",
	"version": "0.1.0",
	"description": "WhatsApp Translator Agent",
	"type": "module",
	"bin": {
		"wa-translate": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx cp -r src/skills dist/skills && shx chmod +x dist/main.js || true",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"start": "node dist/main.js",
		"check": "tsc --noEmit",
		"test:slang": "tsx test-slang.ts"
	},
	"dependencies": {
		"@whiskeysockets/baileys": "^7.0.0-rc.9",
		"qrcode-terminal": "^0.12.0",
		"dotenv": "^16.4.7",
		"@mariozechner/pi-ai": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@types/qrcode-terminal": "^0.12.2",
		"shx": "^0.3.4",
		"typescript": "^5.7.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
